@Article{Banker1989a,
  author = {Rajiv D. Banker and Srikant M. Datar},
  title = {{Sensitivity, Precision, and Linear Aggregation of Signals for Performance Evaluation.}},
  journal = {Journal of Accounting Research},
  groups = {Accounting},
  year = {1989},
  volume = {27},
  number = {1},
  pages = {21--40},
  abstract = {{The article focuses on methods of evaluating management performance from which optimal compensation contracts are based. It mentions that due to the cost and impracticability of evaluating the performance of managers via comprehensive reports of all their basic transactions and other non-financial information, the demand for aggregation in evaluating managers has risen. It states that optimal compensation contract design was split into two stages: developing a measure of evaluation for managerial performance, and using that measure to choose a compensation contract.}},
