}

@Article{Iannotta2016,
  order = {60567},
  author = {Michela Iannotta and Mauro Gatti and Morten Huse},
  title = {{Institutional Complementarities and Gender Diversity on Boards: A Configurational Approach.}},
  journal = {Corporate Governance: An International Review},
