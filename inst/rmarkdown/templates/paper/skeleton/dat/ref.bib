  author = {Bruce Kogut and Jordi Colomer and Mariano Belinky},
  title = {{Structural Equality at the Top of the Corporation: Mandated Quotas for Women Directors.}},
  journal = {Strategic Management Journal},
  jnl = {SMJ},
  issn = {01432095},
  field = {Management},
  year = {2014},
  volume = {35},
  number = {6},
  pages = {891--903},
  doi = {10.1002/smj.2123},
  abstract = {{We propose a concept of structural equality as a compromise between competing policy preferences of equality and individual liberty to address a stunning property of the governance of corporations, namely, the paucity of female directors on corporate boards. An argument for imposing a quota for women directors on boards is the need to disrupt structural impediments to permit endogenous mechanisms to sustain female recruitment beyond a critical mass. Using estimates from the norwegian experiment, we apply an agent-based model to american board data to show that modest numerical quotas generate well-connected networks of women directors who attain equality in their centrality and influence. The analysis demonstrates the utility of computational social science for identifying policies that generate alternative and possible worlds of greater structural equality. Copyright (c) 2013 john wiley \& sons, ltd.}},
  keywords = {corporate governance; research; women directors of corporations; boards of directors; affirmative action programs; administration of human resource programs (except education, public health, and veterans' affairs programs); social justice; multiagent systems_boards of directors and gender; computational social science; quotas; social justice; structural equality},
}

